# NanoChat-JAX Environment Variables

# JAX configuration
JAX_PLATFORMS=cpu  # Set to "cuda" for GPU
# JAX_DEFAULT_DTYPE=bfloat16

# Weights & Biases
# WANDB_API_KEY=your_key_here
# WANDB_PROJECT=nanochat-jax
# WANDB_ENTITY=your_entity

# Data paths
# NANOCHAT_DATA_DIR=data/
# NANOCHAT_CHECKPOINT_DIR=checkpoints/

# Training
# NANOCHAT_SEED=42
# NANOCHAT_DTYPE=bfloat16
